# SERVER (Rust / Docker)
PORT=8080
DATABASE_TARGET=local
DATABASE_URL_LOCAL=postgres://user:password@localhost:5432/neural_db
DATABASE_URL_DOCKER=postgres://user:password@db:5432/neural_db
FRONTEND_URL=http://localhost:3000

MODEL_VERSION=v1.0
MODEL_ASSET_PATH=../frontend/public/model.json
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=neural_db

# FRONTEND (React/Vite)
VITE_API_BASE_URL=http://localhost:8080/api
VITE_MODEL_VERSION=v1.0
VITE_TELEMETRY_ENABLED=false